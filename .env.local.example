# Copy this file to .env.local and replace the placeholder with your Gemini or OpenAI API key
GEMINI_API_KEY=your_gemini_api_key_here
# Alternatively:
# OPENAI_API_KEY=your_openai_api_key_here
# Optional: override the default OpenAI/Gemini model
# OPENAI_MODEL=gpt-4.1-mini
# GEMINI_MODEL=gpt-4.1-mini
# If you hit quota errors, check your OpenAI usage and billing dashboard.
